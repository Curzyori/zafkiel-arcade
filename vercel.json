{
  "version": 2,
  "builds": [
    {
      "src": "interface/api/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["interface/web/dist/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "interface/api/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "interface/api/server.js"
    }
  ]
}
